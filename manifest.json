{
  "mcpb_version": "0.1",
  "name": "wix-dataverse",
  "display_name": "Wix Dataverse",
  "version": "5.0.0",
  "description": "Full-stack Dynamics 365 / Dataverse tooling for the Wix org.",
  "long_description": "70 tools for metadata exploration, CRUD, plugin management, solution ALM, security auditing, web resources, audit history, managed identities, and more. Covers all 6 Wix Dataverse environments (DEV, POC, INT, Test, UAT, Prod). Authenticate with your Azure AD app Client ID and Client Secret on first use.",
  "author": {
    "name": "Wix Dynamics 365 Team"
  },
  "license": "MIT",
  "server": {
    "type": "node",
    "entry_point": "mcp-server/dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/mcp-server/dist/index.js"]
    }
  },
  "tools": [
    { "name": "authenticate", "description": "Authenticate with your Azure AD Client ID and Client Secret" },
    { "name": "auth_status", "description": "Check authentication and connection status" },
    { "name": "list_environments", "description": "List all Wix Dataverse environments" },
    { "name": "select_environment", "description": "Set the active environment" },
    { "name": "add_environment", "description": "Add a Dataverse environment at runtime" },
    { "name": "list_entities", "description": "List all entities" },
    { "name": "get_entity_details", "description": "Get full entity metadata" },
    { "name": "get_entity_fields", "description": "List fields for an entity" },
    { "name": "get_entity_relationships", "description": "Get entity relationships" },
    { "name": "get_option_set", "description": "Get option set values" },
    { "name": "get_global_option_set", "description": "Get global option set" },
    { "name": "get_entity_keys", "description": "Get alternate keys" },
    { "name": "list_entities_by_solution", "description": "List entities in a solution" },
    { "name": "query_records", "description": "Query records with OData" },
    { "name": "create_record", "description": "Create a record" },
    { "name": "update_record", "description": "Update a record" },
    { "name": "delete_record", "description": "Delete a record" },
    { "name": "fetch_xml_query", "description": "Execute FetchXML" },
    { "name": "associate_records", "description": "Associate records" },
    { "name": "disassociate_records", "description": "Disassociate records" },
    { "name": "batch_operations", "description": "Execute batch operations" },
    { "name": "list_users", "description": "List system users" },
    { "name": "list_security_roles", "description": "List security roles" },
    { "name": "get_user_roles", "description": "Get user's roles" },
    { "name": "list_teams", "description": "List teams" },
    { "name": "list_queues", "description": "List queues" },
    { "name": "compare_user_privileges", "description": "Compare user privileges" },
    { "name": "assign_security_role", "description": "Assign a security role" },
    { "name": "remove_security_role", "description": "Remove a security role" },
    { "name": "list_plugin_assemblies", "description": "List plugin assemblies" },
    { "name": "list_plugin_types", "description": "List plugin types" },
    { "name": "list_sdk_messages", "description": "List SDK messages" },
    { "name": "list_sdk_message_filters", "description": "List message filters" },
    { "name": "list_processing_steps", "description": "List plugin steps" },
    { "name": "get_step_details", "description": "Get step details" },
    { "name": "create_processing_step", "description": "Create a plugin step" },
    { "name": "update_processing_step", "description": "Update a plugin step" },
    { "name": "delete_processing_step", "description": "Delete a plugin step" },
    { "name": "enable_processing_step", "description": "Enable a step" },
    { "name": "disable_processing_step", "description": "Disable a step" },
    { "name": "list_step_images", "description": "List step images" },
    { "name": "create_step_image", "description": "Create a step image" },
    { "name": "delete_step_image", "description": "Delete a step image" },
    { "name": "list_service_endpoints", "description": "List webhooks/endpoints" },
    { "name": "get_service_endpoint", "description": "Get endpoint details" },
    { "name": "create_service_endpoint", "description": "Create a webhook" },
    { "name": "update_service_endpoint", "description": "Update an endpoint" },
    { "name": "delete_service_endpoint", "description": "Delete an endpoint" },
    { "name": "register_webhook_step", "description": "Register a webhook step" },
    { "name": "list_plugin_trace_logs", "description": "Get plugin trace logs" },
    { "name": "list_custom_actions", "description": "List custom actions" },
    { "name": "get_custom_action_details", "description": "Get custom action details" },
    { "name": "list_custom_apis", "description": "List custom APIs" },
    { "name": "get_custom_api_details", "description": "Get custom API details" },
    { "name": "list_solutions", "description": "List solutions" },
    { "name": "get_solution_components", "description": "Get solution components" },
    { "name": "get_solution_dependencies", "description": "Get solution dependencies" },
    { "name": "export_solution", "description": "Export a solution" },
    { "name": "import_solution", "description": "Import a solution" },
    { "name": "publish_customizations", "description": "Publish customizations" },
    { "name": "list_web_resources", "description": "List web resources" },
    { "name": "get_web_resource", "description": "Read a web resource" },
    { "name": "create_web_resource", "description": "Create a web resource" },
    { "name": "update_web_resource", "description": "Update a web resource" },
    { "name": "get_audit_history", "description": "Get audit history" },
    { "name": "get_entity_audit_status", "description": "Check entity audit status" },
    { "name": "get_field_audit_status", "description": "Check field audit status" },
    { "name": "get_org_audit_status", "description": "Check org audit status" },
    { "name": "list_environment_variables", "description": "List environment variables" },
    { "name": "get_environment_variable", "description": "Get an env variable" },
    { "name": "set_environment_variable", "description": "Set an env variable" },
    { "name": "list_managed_identities", "description": "List managed identities" },
    { "name": "create_managed_identity", "description": "Create managed identity" },
    { "name": "associate_managed_identity", "description": "Associate managed identity with assembly" },
    { "name": "compute_credential_subject", "description": "Compute federated credential subject" },
    { "name": "get_org_settings", "description": "Get org settings" },
    { "name": "toggle_trace_logging", "description": "Toggle plugin trace logging" }
  ],
  "keywords": ["dynamics365", "dataverse", "crm", "power-platform"],
  "compatibility": {
    "platforms": ["win32", "darwin"],
    "runtimes": {
      "node": ">=18.0.0"
    }
  }
}
